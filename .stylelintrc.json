{
  "extends": "stylelint-config-standard",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "tailwind",
          "layer",
          "apply",
          "import"
        ]
      }
    ],
    "declaration-property-unit-allowed-list": {
      "/^--color-/": [
        "oklch",
        "%"
      ]
    }
  }
}
